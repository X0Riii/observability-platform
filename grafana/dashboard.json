{
  "title": "OBS Platform Overview",
  "version": 2,
  "panels": [
    {
      "title": "HTTP Requests Rate",
      "type": "graph",
      "targets": [{
        "expr": "rate(obs_http_requests_total[1m])",
        "legendFormat": "{{method}} {{route}}"
      }]
    },
    {
      "title": "HTTP Request Duration (P95)",
      "type": "graph",
      "targets": [{
        "expr": "histogram_quantile(0.95, rate(obs_http_request_duration_ms_bucket[5m]))",
        "legendFormat": "{{method}} {{route}}"
      }]
    },
    {
      "title": "Active Sessions",
      "type": "stat",
      "targets": [{ "expr": "obs_active_sessions" }]
    },
    {
      "title": "Kafka Messages",
      "type": "graph",
      "targets": [{
        "expr": "rate(obs_kafka_messages_total[1m])",
        "legendFormat": "{{topic}} ({{direction}})"
      }]
    },
    {
      "title": "OpenSearch Indexed Documents",
      "type": "graph",
      "targets": [{
        "expr": "rate(obs_opensearch_indexed_total[1m])",
        "legendFormat": "{{index}}"
      }]
    },
    {
      "title": "Collector Queue Depth",
      "type": "stat",
      "targets": [{ "expr": "obs_collector_queue_depth" }]
    }
  ]
}
